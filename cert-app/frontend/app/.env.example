# 로컬: 아래. 프로덕션: Railway API (예: https://certfinder-production.up.railway.app/api/v1)
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ──────────────────────────────────────────────
# Supabase (프론트엔드 Auth 클라이언트용)
# Supabase 프로젝트 페이지 > Project Settings > API 탭에서 확인
# ──────────────────────────────────────────────
VITE_SUPABASE_URL=https://<PROJECT_REF>.supabase.co
VITE_SUPABASE_ANON_KEY=<SUPABASE_ANON_KEY>

# 주의: PostgreSQL 연결 문자열(Direct/Pooler)은 프론트에 넣지 마세요. Vite 번들·저장소 노출 위험. 백엔드 .env만 사용.
