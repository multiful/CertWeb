PROJECT_NAME="Certification API"
DEBUG=True
API_V1_PREFIX="/api/v1"

# ──────────────────────────────────────────────
# PostgreSQL (Supabase)
# Supabase 프로젝트 페이지 > Project Settings > Database > Connection string (URI)
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@<SUPABASE_HOST>:6543/postgres

# ──────────────────────────────────────────────
# Supabase Auth & API
# Supabase 프로젝트 페이지 > Project Settings > API 탭에서 확인
# ──────────────────────────────────────────────
SUPABASE_URL=https://<PROJECT_REF>.supabase.co
SUPABASE_ANON_KEY=<SUPABASE_ANON_KEY>
SUPABASE_SERVICE_ROLE_KEY=<SUPABASE_SERVICE_ROLE_KEY>
SUPABASE_JWT_SECRET=<SUPABASE_JWT_SECRET>

# Redis Cloud (https://app.redislabs.com)
# redis://<USER>:<PASSWORD>@<HOST>:<PORT>
# ──────────────────────────────────────────────
REDIS_URL=redis://default:<PASSWORD>@<REDIS_HOST>:<PORT>

# ──────────────────────────────────────────────
# SMTP 이메일 (인증 메일 발송용)
# ──────────────────────────────────────────────
SMTP_HOST=smtp.naver.com
SMTP_PORT=587
EMAIL_USER=<YOUR_EMAIL>@naver.com
EMAIL_PASSWORD=<NAVER_APP_PASSWORD>
# 문의 폼 수신 주소(비우면 EMAIL_USER로 수신)
CONTACT_EMAIL=<YOUR_EMAIL>@naver.com

# ──────────────────────────────────────────────
# OpenAI API (AI 추천 기능)
# https://platform.openai.com/api-keys
# ──────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-<YOUR_OPENAI_KEY>
# 임베딩 모델(메타 emb_model_version·재색인 drift 추적). 기본 text-embedding-3-small (1536차원)
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ──────────────────────────────────────────────
# Admin Job Secret (관리자 API 보호용 임의 비밀키)
# ──────────────────────────────────────────────
JOB_SECRET=<RANDOM_SECRET_STRING>

# ──────────────────────────────────────────────
# Reranker (HF Space API 전용, 로컬 모델 미사용)
# Colab에서 파인튜닝 후 Hub에 올린 모델 → Space에서 서빙. 여기선 inference URL만 설정.
# ──────────────────────────────────────────────
# 리랭커: 코드 기본값은 false. 모델 재학습·배포 후 아래를 true로 켜는 것을 권장.
# RAG_USE_CROSS_ENCODER_RERANKER=true
# RAG_RERANKER_MODEL_REPO_ID=multifuly/certweb-reranker-model
# RAG_RERANKER_SPACE_REPO_ID=multifuly/certweb-reranker
# RAG_RERANKER_API_URL=https://multifuly-certweb-reranker.hf.space
# HF Space 일시 500/429 시 추가 재시도 횟수(기본 2 → 최대 3회 호출)
# RAG_RERANKER_HTTP_RETRIES=2
# RAG_RERANK_GATING_ENABLE=true
# RAG_RERANK_GATING_TOP1_MIN_SCORE=0.02
# RAG_RERANK_GATING_MIN_GAP=0.002

# ──────────────────────────────────────────────
# Contrastive retriever (768-dim 한국어 bi-encoder + FAISS, 3-way RRF용)
# Contrastive = 공식 768-dim 모델만 해당. Hub: multifuly/cert-constrative-embedding.
# jhgan/ko-sroberta-multitask 등 일반 768-dim 한국어 모델은 contrastive가 아님.
# ──────────────────────────────────────────────
# RAG_CONTRASTIVE_ENABLE=true
# RAG_CONTRASTIVE_INDEX_DIR=data/contrastive_index
# RAG_CONTRASTIVE_MODEL=multifuly/cert-constrative-embedding
# (원격 임베딩 사용 시: 아래 URL 설정하면 로컬/Hub 모델 미로드, 질의만 URL로 POST)
# RAG_CONTRASTIVE_EMBEDDING_URL=
# RAG_CONTRASTIVE_EMBEDDING_TOKEN=

# Hugging Face (Colab: data/contrastive_train/train_contrastive_colab.py 업로드·다운로드)
# 코드에 토큰을 넣지 말고 여기 또는 Colab Secrets에만 설정. 채팅/PR에 노출 시 즉시 폐기·재발급.
# HF_TOKEN_READ=hf_...   # 읽기 전용: 베이스 모델 다운로드 rate limit 완화
# HF_TOKEN_WRITE=hf_...  # 쓰기: Hub에 학습 모델 push
# 단일 토큰(읽기+쓰기 권한)만 있으면 아래 하나만 써도 됨.
# HF_TOKEN=hf_...

# ── Retrieval 고도화 (리랭커 제외: RRF·BM25·벡터·contrastive·메타만) ──
# 계층 검색: certificates_vectors.content 문단 단위 BM25 → qual_id로 환원 후 BM25 채널과 블렌딩. 기본 ON.
# 끄려면: RAG_HIERARCHICAL_RETRIEVAL_ENABLE=false
# RAG_HIERARCHICAL_BLEND_WEIGHT=0.35
# 계층 child BM25: 기본 코드값 0 = 매 질의 COUNT(스냅샷·랭킹 동일). 지연만 줄이려면 30~45 등 설정(그만큼 인덱스 갱신 지연 허용).
# RAG_HIERARCHICAL_STAT_SKIP_SEC=0
# hybrid 최종 후보 Redis 캐시(동일 질의 재호출 시 지연↓). 프로필/필터/리랭커 없을 때만 적용. Redis 없으면 무시.
# 끄려면: RAG_RETRIEVAL_RESULT_CACHE_ENABLE=false
# RAG_RETRIEVAL_RESULT_CACHE_TTL_SECONDS=300
# Contrastive: 원격 임베딩 URL이 500 등이면 2회 실패 후 5분간 URL 스킵·로컬 ST 폴백. 안정 우선이면 URL 비우고 RAG_CONTRASTIVE_MODEL만 사용.
# 튜닝: 그리드 서치 금지(자원 과다). 랜덤 서치만 — scripts/rag_random_search.py --golden ... --trials N --seed S [--max-queries K] [--top-k 5]
# 프로덕션 RAG A/B. false면 트래픽 분할 없음.
# control=코드·.env 기본(레거시) / challenger=RAG_CHALLENGER_PRESET(랜덤서치 후보, 전체 골든으로 검증 필수)
# RAG_AB_ENABLE=false
# RAG_AB_CHALLENGER_PCT=50
# 스테이징: X-RAG-Variant: control | challenger 가 분할보다 우선
# RAG_AB_ALLOW_HEADER_OVERRIDE=false

# RRF·linear 병합 전 후보 풀 크기. 오프라인: scripts/ab_golden_hybrid_tuning.py 로 품질·지연 A/B 권장.
# RAG_TOP_N_CANDIDATES=96
# 퓨전: linear | combmnz | combsum (rrf 는 내부적으로 linear 취급). 골든 A/B: scripts/ab_golden_hybrid_tuning.py
# RAG_FUSION_METHOD=linear
# 계층 BM25: 매 요청 COUNT(*) 왕복 생략(초). 기본 45(config). 재색인 직후 최대 이 시간 스테일 가능.
# RAG_HIERARCHICAL_STAT_SKIP_SEC=45
# 3-way RRF 채널 가중(코드 기본은 오프라인 골든 A/B 반영). 튜닝: scripts/eval_retrieval_ab_compare.py / rag_random_search.py
# RAG_RRF_W_BM25=0.6
# RAG_RRF_W_DENSE1536=0.55
# RAG_RRF_W_CONTRASTIVE768=1.05
# 질의 유형 게이팅 (contrastive arm / Cross-Encoder 리랭커)
# DB 벡터 query_type 라벨이 없거나 분류 실패 시 hybrid 는 keyword | natural | mixed 만 사용.
# 옛 타입(comparison, roadmap, purpose_only 등)만 allowlist 에 두면 fallback 경로에서 허용 불일치로
# contrastive·리랭커가 의도치게 스킵될 수 있음.
# RAG_CONTRASTIVE_ALLOWED_QUERY_TYPES=keyword,natural,mixed
# RAG_RERANK_ALLOWED_QUERY_TYPES=keyword,natural,mixed

# Dense rewrite (벡터/하이브리드 검색 시 재질의)
RAG_DENSE_USE_QUERY_REWRITE=true
# BM25 PRF 미사용 시에만: 벡터(+HyDE 등)와 BM25를 스레드 2개로 병렬 실행(p95 완화). PRF 켜면 자동 순차.
# RAG_HYBRID_BM25_VECTOR_PARALLEL_ENABLE=true
# 원문+재작성 이중 벡터 RRF: divergence(기본) | legacy_non_it_only | off
# RAG_DUAL_VECTOR_RRF_WHEN=divergence
# 골든 평가(runner)에서 hybrid가 반환하는 최종 후보 개수. Recall@5/10과 맞추려면 >=10 권장.
# RAG_EVAL_TOP_K=10
# NCS CSV → 인덱스 본문: false=레거시(기본, DB ncs_large만). true=mapped+중직무 반영(컬럼·CSV·재색인 필수).
RAG_CANONICAL_NCS_CSV=false
# true 시 CSV 기본: dataset/ncs_mapping_resolved.csv (없으면 ncs_mapping1.csv). 생성: scripts/export_resolved_ncs_csv.py
# 3-way linear fusion LONG 분기 가중치(세 값 모두 설정 시에만 적용, 합으로 정규화). 미설정 시 코드 상수 사용.
# RAG_LINEAR_QT_LONG_W_BM25=0.38
# RAG_LINEAR_QT_LONG_W_DENSE=0.24
# RAG_LINEAR_QT_LONG_W_CONTRASTIVE=0.38
# linear fusion 후 BM25 순위 소량 가산 (0=비활성, 시험: 0.004~0.012)
# RAG_LINEAR_BM25_RANK_PRIOR=0.008
# 메타 soft 적용 직후 BM25 순위 보조 (0=비활성)
# RAG_POST_METADATA_BM25_RANK_PRIOR=0.004
# EXACT 분기(짧은 키워드/자격증명) 오버라이드 — 필요 시만
# RAG_LINEAR_QT_EXACT_W_BM25=
# RAG_LINEAR_QT_EXACT_W_DENSE=
# RAG_LINEAR_QT_EXACT_W_CONTRASTIVE=
# 메타 soft 후 도메인 불일치 대형 감점(슬롯·DB 노이즈 시 정답 밀림) — 엄격 필터 필요 시만 true
# RAG_METADATA_OUT_OF_SCOPE_HARD_ENABLE=false
# 메타데이터 soft(퓨전 직후 점수 보정). 미사용 시 아래 유지 또는 변수 제거(코드 기본도 false). true면 DB 메타 bulk·슬롯 비용↑
RAG_METADATA_SOFT_SCORE_ENABLE=false
# 메타 soft: qualification.main_field를 직무 슬롯 합집합에 넣어 매칭 가산할지. false면 main_field는 job 매칭에서 제외(오프라인 A/B: scripts/eval_retrieval_ab_compare.py)
# RAG_METADATA_SOFT_MAIN_FIELD_IN_JOB_MATCH=true
# 도메인 슬롯은 맞는데 자격증 메타 도메인이 어긋난 것으로 보일 때 추가 소프트 감점(기본 -0.15, 완화 실험: -0.08~-0.10)
# RAG_QUERY_OUT_OF_SCOPE_SOFT_PENALTY=-0.15
# 취득 자격증 hard exclusion (hybrid 후보에서 제거)
# RAG_ACQUIRED_CANDIDATE_HARD_EXCLUDE_ENABLE=true
# 프로필 있을 때 재질의 문자열에서 전공·학년을 '질문:' 뒤로 (발화 우선)
# RAG_PERSONALIZED_MAJOR_AFTER_QUERY=true
# Pre-retrieval 정합: fusion 직전 구조화 trace JSON 로그 (opt_Pre-retrieval.md §2)
# RAG_PRE_RETRIEVAL_TRACE_ENABLE=false
# 확장 경로 잔여 시간 게이트(ms). 코드 기본 15000. 끄려면 0
# RAG_PRE_RETRIEVAL_BUDGET_MS=15000
# hybrid 입력 질의 최대 길이(초과 시 잘림, DoS 완화)
# RAG_QUERY_MAX_CHARS=12000
# Redis: 동일 질의 hybrid 최종 후보 캐시(리랭커·필터·프로필 없을 때만). Railway 등 Redis 필수
# RAG_RETRIEVAL_RESULT_CACHE_ENABLE=false
# RAG_RETRIEVAL_RESULT_CACHE_TTL_SECONDS=300
# 식별자·코드 위주 질의에서 확장 스킵 (dense_query_rewrite.query_suggests_identifier_heavy)
# 식별자·코드 위주 질의에서 HyDE·키워드 확장 등 스킵 (기본 true, opt_Pre-retrieval §2)
# RAG_SKIP_EXPANSION_ON_IDENTIFIER_HEAVY=true
# §2 규칙 4: 식별자 질의에서 구조화 dense rewrite 생략 (기본 true)
# RAG_SKIP_DENSE_REWRITE_ON_IDENTIFIER_HEAVY=true
# §2 규칙 7: RAG_PRE_RETRIEVAL_BUDGET_MS가 이 값(ms) 미만이면 dense rewrite 생략 (미설정 시 예산만으로는 rewrite 안 끔)
# RAG_PRE_RETRIEVAL_REWRITE_MIN_BUDGET_MS=120

# AI 하이브리드 추천(/recommendations/ai/hybrid-recommendation) 지연: RAG와 전공 임베딩 병렬 + 후보 소폭 cap
# false 시 전역 RAG 깊이와 동일(느릴 수 있음)
# AI_RECOMMEND_RAG_FAST=true
# 후보 상한(미설정 시 코드 기본 cap 과 RAG 설정의 min). 필요 시만 조정
# AI_RECOMMEND_CAP_TOP_N=102
# AI_RECOMMEND_CAP_BM25_N=76
# AI_RECOMMEND_CAP_VECTOR_N=76
# AI_RECOMMEND_CAP_CONTRASTIVE_N=68

# 관심사(interest) 입력 시 전공 맵 vs RAG 후보 균형. 산업데이터+품질처럼 RAG만 쏠릴 때 BASE·TRIM을 0.38~0.45대로 실험.
# HYBRID_INTEREST_SEM_RRF_WEIGHT=2.6
# HYBRID_INTEREST_TRIM_MAJOR_BLEND=0.35
# HYBRID_INTEREST_BASE_MAJOR_BLEND=0.22

# ──────────────────────────────────────────────
# 네이버 검색 API (scripts/fill_cert_descriptions.py - 자격증 설명 수집)
# https://developers.naver.com/apps → 애플리케이션 등록 후 검색 API 사용 설정
# ──────────────────────────────────────────────
# NAVER_CLIENT_ID=<YOUR_NAVER_CLIENT_ID>
# NAVER_CLIENT_SECRET=<YOUR_NAVER_CLIENT_SECRET>
